{
  "version": 2,
  "functions": {
    "api/gemini.js": { "maxDuration": 60 },
    "api/lead.js": { "maxDuration": 60 },
    "api/partner.js": { "maxDuration": 60 },
    "api/partner-status.js": { "maxDuration": 30 },
    "api/partner-approve.js": { "maxDuration": 30 },
    "api/partners-list.js": { "maxDuration": 10 },
    "api/partner-edit.js": { "maxDuration": 30 },
    "api/weekly-digest.js": { "maxDuration": 30 }
  },
  "crons": [
    {
      "path": "/api/weekly-digest",
      "schedule": "0 4 * * 1"
    }
  ],
  "rewrites": [
    { "source": "/partner-apply", "destination": "/partner-apply.html" },
    { "source": "/partner-portal", "destination": "/partner-portal.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
